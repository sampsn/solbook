# Supabase — server-side only (never expose to client)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# No NEXT_PUBLIC_SUPABASE_URL — client code never talks to Supabase directly
# No NEXT_PUBLIC_SUPABASE_ANON_KEY — anon role has no permissions

# WebAuthn / Passkey
NEXT_PUBLIC_RP_ID=localhost
NEXT_PUBLIC_ORIGIN=http://localhost:3000

# Upstash Redis (rate limiting + IP blacklisting)
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
